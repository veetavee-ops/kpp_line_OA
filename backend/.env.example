NODE_ENV=development
PORT=3000

# LINE Bot — จาก LINE Developers Console → Messaging API
CHANNEL_ACCESS_TOKEN=
CHANNEL_SECRET=

# CORS
FRONTEND_URL=http://localhost:5173

# AI — Gemini (จาก aistudio.google.com)
GEMINI_API_KEY=

# AI — Groq (จาก console.groq.com → API Keys)
GROQ_API_KEY=

# JWT Auth — ตั้งเองได้เลย
JWT_SECRET=
REGISTER_SECRET=

# Database — Neon PostgreSQL (จาก console.neon.tech)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
DB_SSL=true

# Google Cloud Storage
GCS_KEY_FILE=./config/gcs-key.json
GCS_BUCKET_NAME=

# Google Drive OAuth2 (จาก console.cloud.google.com → OAuth2)
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=

# Admin LINE UserID (กด Share → Copy ID ใน LINE app)
ADMIN_LINE_USER_ID=

# ngrok (จาก dashboard.ngrok.com → Your Authtoken)
NGROK_AUTHTOKEN=
